---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <span class="footer-name">Austin Larsen</span>
      <span class="footer-sep">&middot;</span>
      <span class="footer-role">Threat Research</span>
    </div>
    <div class="footer-right">
      <a href="https://signal.me/#eu/B9Xfu0Xy5yiT_bunPy9GMuz8XqT0B-zcyd8pJtYuROPE8CpyVaJNZq78ckSNXUNV" target="_blank" rel="noopener">Signal</a>
      <span class="footer-sep">&middot;</span>
      <a href="mailto:mail@austinlarsen.me">Email</a>
      <span class="footer-sep">&middot;</span>
      <span class="footer-copy">&copy; {year}</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 32px 0;
    margin-top: 40px;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .footer-name { color: var(--text-secondary); font-weight: 500; }
  .footer-sep { margin: 0 6px; }
  .footer-right { display: flex; align-items: center; gap: 4px; }
  .footer-right a {
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .footer-right a:hover { color: var(--text-primary); }
  .footer-copy { color: var(--text-muted); }
</style>
