    '/clear': {
      description: 'Clear terminal',
      action: () => null, // handled specially
    },
  };

  const body = document.getElementById('terminal-body')!;
  const inputRow = document.getElementById('terminal-input-row')!;
  const input = document.getElementById('terminal-input')! as HTMLInputElement;
  const CHAR_DELAY = 28;
  const LINE_DELAY = 50;
  const PROMPT_PAUSE = 400;

  function sleep(ms: number): Promise<void> {
    return new Promise(r => setTimeout(r, ms));
  }

  function createLine(): HTMLDivElement {
    const line = document.createElement('div');
    line.className = 't-line';
    body.appendChild(line);
    return line;
  }

  function addOutput(html: string) {
    const line = createLine();
    line.classList.add('t-output');
    if (html === '') {
      line.innerHTML = '&nbsp;';
    } else {
      line.innerHTML = html;
    }
  }

  async function typeText(el: HTMLElement, text: string) {
    for (let i = 0; i < text.length; i++) {
      el.textContent += text[i];
      await sleep(CHAR_DELAY);
    }
  }

  function scrollToBottom() {
    body.scrollTop = body.scrollHeight;
  }

  // ── Startup animation ──
  async function runStartup() {
    // Wait until element is in view
    await new Promise<void>(resolve => {
      const observer = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) { observer.disconnect(); resolve(); }
      }, { threshold: 0.3 });
      observer.observe(body);
    });

    for (const step of STARTUP_SCRIPT) {
      await sleep(step.delay ?? LINE_DELAY);

      if (step.type === 'prompt') {
        await sleep(PROMPT_PAUSE);
        const line = createLine();
        const prompt = document.createElement('span');
        prompt.className = 't-prompt';
        prompt.textContent = '$ ';
        line.appendChild(prompt);

        const cmd = document.createElement('span');
        cmd.className = 't-command';
        line.appendChild(cmd);

        const cursor = document.createElement('span');
        cursor.className = 't-cursor';
        line.appendChild(cursor);

        await typeText(cmd, step.text);
        cursor.remove();
      } else {
        addOutput(step.text);
      }

      scrollToBottom();
    }

    // Show the interactive input
    scrollToBottom();

    // Show the interactive input row
    inputRow.style.visibility = 'visible';
    input.focus();
  }

  // ── Interactive command handler ──
  function handleCommand(rawInput: string) {
    const cmd = rawInput.trim().toLowerCase();

    // Echo the command
    const echoLine = createLine();
    const prompt = document.createElement('span');
    prompt.className = 't-prompt';
    prompt.textContent = '$ ';
    echoLine.appendChild(prompt);
    const cmdSpan = document.createElement('span');
    cmdSpan.className = 't-command';
    cmdSpan.textContent = rawInput.trim();
    echoLine.appendChild(cmdSpan);

    if (cmd === '/clear') {
      body.innerHTML = '';
      addOutput('<span class="t-highlight">Type /help for available commands</span>');
      scrollToBottom();
      return;
    }

    if (cmd === '' ) {
      scrollToBottom();
      return;
    }

    const handler = COMMANDS[cmd];
    if (handler) {
      const output = handler.action();
      if (output) {
        output.forEach(line => addOutput(line));
      }
    } else {
      addOutput(`<span class="t-error">command not found: ${cmd.replace(/</g, '&lt;')}</span>`);
      addOutput('Type <span class="t-command">/help</span> for available commands');
    }

    scrollToBottom();
  }

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      handleCommand(input.value);
      input.value = '';
    }
  });

  // Click anywhere on terminal to focus input
  document.getElementById('terminal')!.addEventListener('click', () => {
    if (inputRow.style.visibility !== 'hidden') {
      input.focus();
    }
  });

  // ── Secret mode ──
  function triggerSecretMode() {
    // Matrix rain canvas
    const canvas = document.createElement('canvas');
    canvas.id = 'secret-canvas';
    canvas.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9997;opacity:0;transition:opacity 0.6s;';
    document.body.appendChild(canvas);
    const ctx = canvas.getContext('2d')!;
    const setSize = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; };
    setSize();
    window.addEventListener('resize', setSize);
    setTimeout(() => { canvas.style.opacity = '0.22'; }, 50);

    const matrixChars = 'アイウエオカキクケコサシスセソ0123456789ABCDEF<>/\\[]{}=+*#%@!?▓▒░';
    const fontSize = 13;
    let drops: number[] = [];
    const initDrops = () => { drops = Array(Math.floor(canvas.width / fontSize)).fill(0).map(() => Math.random() * -60); };
    initDrops();

    const matrixInterval = setInterval(() => {
      ctx.fillStyle = 'rgba(0,0,0,0.05)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      const cols = Math.floor(canvas.width / fontSize);
      while (drops.length < cols) drops.push(0);
      for (let i = 0; i < cols; i++) {
        const ch = matrixChars[Math.floor(Math.random() * matrixChars.length)];
        ctx.fillStyle = '#00ff88';
        ctx.font = `bold ${fontSize}px monospace`;
        ctx.fillText(ch, i * fontSize, drops[i] * fontSize);
        if (drops[i] > 1) {
          ctx.fillStyle = 'rgba(0,255,136,0.4)';
          ctx.fillText(matrixChars[Math.floor(Math.random() * matrixChars.length)], i * fontSize, (drops[i] - 1) * fontSize);
        }
        if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
        drops[i] += 0.6;
      }
    }, 40);

    // Scanline overlay
    const scanlines = document.createElement('div');
    scanlines.id = 'secret-scanlines';
    document.body.appendChild(scanlines);

    // Text scramble
    const GLITCH = '!<>-_\\/[]{}=+*^?#$@%~|;:░▒▓█アカサタナ01';
    const els: Element[] = [];
    const origText = new Map<Element, string>();
    document.querySelectorAll('h1,h2,h3,p,a,span,li,time').forEach(el => {
      if (el.closest('#terminal') || el.closest('#secret-banner') || el.closest('#secret-scanlines')) return;
      if (el.children.length === 0 && el.textContent?.trim()) {
        els.push(el); origText.set(el, el.textContent!);
      }
    });
    const glitchInterval = setInterval(() => {
      els.forEach(el => {
        const orig = origText.get(el)!;
        if (Math.random() > 0.55) {
          const arr = orig.split('');
          const n = Math.ceil(Math.random() * arr.length * 0.45);
          for (let i = 0; i < n; i++) {
            const idx = Math.floor(Math.random() * arr.length);
            if (arr[idx] !== ' ') arr[idx] = GLITCH[Math.floor(Math.random() * GLITCH.length)];
          }
          el.textContent = arr.join('');
        } else {
          el.textContent = orig;
        }
      });
    }, 55);

    // Banner
    const banner = document.createElement('div');
    banner.id = 'secret-banner';
    banner.innerHTML = `
      <div class="sb-label">// root@corp-prod-db01 · SESSION ACTIVE · TLP:RED</div>
      <div class="sb-title">SYSTEM<br>COMPROMISED</div>
      <div class="sb-sub">18 U.S.C § 1030 · All activity logged · <kbd>ESC</kbd> or <span>/restore</span> to disconnect</div>
    `;
    document.body.appendChild(banner);
    document.body.classList.add('secret-mode');

    function cleanup() {
      clearInterval(matrixInterval);
      clearInterval(glitchInterval);
      window.removeEventListener('resize', setSize);
      origText.forEach((orig, el) => { el.textContent = orig; });
      canvas.style.opacity = '0';
      setTimeout(() => canvas.remove(), 600);
      scanlines.remove();
      banner.remove();
      document.body.classList.remove('secret-mode');
      document.removeEventListener('keydown', onEsc);
      document.removeEventListener('secret-restore', cleanup);
    }
    const onEsc = (e: KeyboardEvent) => { if (e.key === 'Escape') cleanup(); };
    document.addEventListener('keydown', onEsc);
    document.addEventListener('secret-restore', cleanup);
    setTimeout(cleanup, 20000);
  }

  runStartup();
</script>
