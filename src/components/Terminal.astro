---
/**
 * Animated terminal hero — types out commands on load,
 * then becomes interactive with a set of slash commands.
 */
---

<div class="terminal" id="terminal">
  <div class="terminal-chrome">
    <div class="terminal-dots">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
    </div>
    <span class="terminal-title">austin@threat-intel ~ %</span>
  </div>
  <div class="terminal-body" id="terminal-body">
    <!-- Lines injected by JS -->
  </div>
  <div class="terminal-input-row" id="terminal-input-row" style="visibility:hidden;">
    <span class="t-prompt">$ </span>
    <input
      type="text"
      class="terminal-input"
      id="terminal-input"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
      placeholder="type /help for commands"
    />
  </div>
</div>

<style>
  .terminal {
    background: #0c0c14;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.7;
    max-width: 720px;
    width: 100%;
    box-shadow:
      0 0 80px rgba(0, 200, 255, 0.06),
      0 24px 48px rgba(0, 0, 0, 0.4);
  }

  .terminal-chrome {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: #111119;
    border-bottom: 1px solid var(--border);
  }
  .terminal-dots {
    display: flex;
    gap: 6px;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot.red { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green { background: #28c840; }
  .terminal-title {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .terminal-body {
    padding: 20px 24px 8px;
    height: 400px;
    overflow-y: auto;
  }

  /* Input row */
  .terminal-input-row {
    display: flex;
    align-items: center;
    padding: 4px 24px 16px;
    gap: 0;
  }
  .terminal-input-row .t-prompt {
    color: var(--green);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    flex-shrink: 0;
  }
  .terminal-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    caret-color: var(--green);
    line-height: 1.7;
  }
  .terminal-input::placeholder {
    color: var(--text-muted);
    opacity: 0.5;
  }

  /* Line types */
  .terminal-body :global(.t-line) {
    white-space: pre-wrap;
    word-break: break-word;
    min-height: 1.7em;
  }
  .terminal-body :global(.t-prompt) {
    color: var(--green);
  }
  .terminal-body :global(.t-command) {
    color: var(--text-primary);
  }
  .terminal-body :global(.t-output) {
    color: var(--text-secondary);
  }
  .terminal-body :global(.t-highlight) {
    color: var(--accent);
  }
  .terminal-body :global(.t-label) {
    color: var(--yellow);
  }
  .terminal-body :global(.t-unc) {
    color: var(--pink);
    font-weight: 500;
  }
  .terminal-body :global(.t-success) {
    color: var(--green);
  }
  .terminal-body :global(.t-error) {
    color: #ff5f57;
  }
  .terminal-body :global(.t-cursor) {
    display: inline-block;
    width: 8px;
    height: 1.1em;
    background: var(--green);
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  @media (max-width: 768px) {
    .terminal { font-size: 0.75rem; }
    .terminal-body { padding: 16px 16px 4px; height: 320px; }
    .terminal-input-row { padding: 4px 16px 12px; }
    .terminal-input { font-size: 0.75rem; }
  }

  /* ── Secret mode global styles ── */
  :global(body.secret-mode) {
    animation: secret-shake 0.1s infinite;
  }
  @keyframes secret-shake {
    0%, 100% { transform: translate(0, 0); }
    25% { transform: translate(-1px, 0); }
    75% { transform: translate(1px, 0); }
  }

  :global(#secret-scanlines) {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9998;
    background: repeating-linear-gradient(
      0deg,
      transparent 0px, transparent 2px,
      rgba(0, 255, 136, 0.035) 2px, rgba(0, 255, 136, 0.035) 4px
    );
    animation: scanroll 0.08s linear infinite;
  }
  @keyframes scanroll {
    to { background-position: 0 4px; }
  }

  :global(#secret-banner) {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10000;
    text-align: center;
    pointer-events: none;
    font-family: monospace;
  }
  :global(#secret-banner .sb-label) {
    font-size: 0.8rem;
    color: #00ff88;
    letter-spacing: 0.18em;
    margin-bottom: 16px;
    opacity: 0.9;
  }
  :global(#secret-banner .sb-title) {
    font-size: clamp(2.4rem, 7vw, 5rem);
    font-weight: 900;
    line-height: 1;
    color: #ff2233;
    text-shadow:
      0 0 30px rgba(255, 34, 51, 0.95),
      0 0 60px rgba(255, 34, 51, 0.5),
      5px 0 0 rgba(0, 200, 255, 0.55),
      -5px 0 0 rgba(0, 255, 136, 0.35);
    animation: banner-glitch 0.18s infinite;
  }
  @keyframes banner-glitch {
    0%, 100% { transform: none; }
    30% { transform: translate(-3px, 1px) skewX(-1deg); }
    60% { transform: translate(3px, -1px) skewX(1deg); }
  }
  :global(#secret-banner .sb-sub) {
    margin-top: 20px;
    font-size: 0.75rem;
    color: rgba(136, 146, 164, 0.75);
    letter-spacing: 0.08em;
  }
  :global(#secret-banner .sb-sub kbd),
  :global(#secret-banner .sb-sub span) {
    font-family: monospace;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 3px;
    padding: 1px 6px;
    font-size: 0.9em;
  }
</style>

<script>
  // ── Startup animation script ──
