          [1100, () => { addOutput('<span class="t-output">Are you sure you want to continue connecting (yes/no/[fingerprint])? yes</span>'); scrollToBottom(); }],
          [1400, () => { addOutput('<span class="t-output">Warning: Permanently added \'185.220.101.47\' (ED25519) to the list of known hosts.</span>'); scrollToBottom(); }],
          [1700, () => { addOutput('<span class="t-output">root@185.220.101.47\'s password: <span class="t-cursor"></span></span>'); scrollToBottom(); }],
          [2400, () => { addOutput('<span class="t-error">Permission denied, please try again.</span>'); scrollToBottom(); }],
          [2700, () => { addOutput('<span class="t-output">root@185.220.101.47\'s password: <span class="t-cursor"></span></span>'); scrollToBottom(); }],
          [3400, () => { addOutput('<span class="t-error">Permission denied, please try again.</span>'); scrollToBottom(); }],
