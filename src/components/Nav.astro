      </div>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    background: rgba(10, 10, 18, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }
  .nav-logo {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
    display: flex;
    align-items: center;
  }
  .nav-logo:hover { color: var(--accent); }
  .nav-prompt {
    color: var(--green);
    margin-right: 6px;
  }
  .nav-name {
    color: var(--text-primary);
    min-width: 0;
  }
  .nav-cursor {
    display: inline-block;
    width: 8px;
    height: 1.15em;
    background: var(--green);
    margin-left: 1px;
    vertical-align: text-bottom;
    animation: navBlink 1s step-end infinite;
  }
  .nav-cursor.done {
    animation: navBlink 1s step-end infinite;
  }
  .nav-cursor.typing {
    animation: none;
    opacity: 1;
  }

  @keyframes navBlink {
    50% { opacity: 0; }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .nav-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color 0.2s;
  }
  .nav-link:hover, .nav-link.active {
    color: var(--text-primary);
  }
  .nav-socials {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: 12px;
    padding-left: 24px;
    border-left: 1px solid var(--border);
  }
  .nav-socials a {
    color: var(--text-muted);
    transition: color 0.2s;
    display: flex;
  }
  .nav-socials a:hover { color: var(--text-primary); }

  /* Mobile toggle */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-secondary);
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  @media (max-width: 768px) {
    .nav-toggle { display: flex; }
    .nav-links {
      display: none;
      position: absolute;
      top: var(--nav-height);
      left: 0;
      right: 0;
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      padding: 24px;
      gap: 16px;
    }
    .nav-links.open { display: flex; }
    .nav-socials {
      border-left: none;
      border-top: 1px solid var(--border);
      margin-left: 0;
      padding-left: 0;
      padding-top: 16px;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');
  toggle?.addEventListener('click', () => links?.classList.toggle('open'));

  // Typewriter effect for nav name
  const nameEl = document.getElementById('nav-name')!;
  const cursorEl = document.getElementById('nav-cursor')!;
  const fullName = 'austin_larsen';

  cursorEl.classList.add('typing');

  async function typeName() {
    await new Promise(r => setTimeout(r, 300));
    for (let i = 0; i < fullName.length; i++) {
      nameEl.textContent += fullName[i];
      await new Promise(r => setTimeout(r, 65));
    }
    cursorEl.classList.remove('typing');
    cursorEl.classList.add('done');
  }

  typeName();
</script>
