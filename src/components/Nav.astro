---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/#research', label: 'Research' },
  { href: '/#talks', label: 'Talks' },
  { href: '/#media', label: 'Media' },
];
---

<nav class="nav" id="nav">
  <div class="nav-inner container">
    <a href="/" class="nav-logo" id="nav-logo">
      <span class="nav-prompt">$</span>
      <span class="nav-name" id="nav-name"></span>
      <span class="nav-cursor" id="nav-cursor"></span>
    </a>

    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>

    <div class="nav-links" id="nav-links">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class:list={['nav-link', { active: currentPath === href }]}
        >
          {label}
        </a>
      ))}

      <div class="nav-socials">
        <a href="https://github.com/austin-larsen" target="_blank" rel="noopener" aria-label="GitHub">
