---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal.astro';
import { getCollection } from 'astro:content';

const research = (await getCollection('research')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const talks = (await getCollection('talks')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const allMedia = (await getCollection('media')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const featuredMedia = allMedia.filter(m => m.data.featured);
const listMedia = allMedia.filter(m => !m.data.featured);
const blogPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const recentBlog = blogPosts.slice(0, 4);
---

<Base title="Austin Larsen — Threat Intelligence">

  <!-- ══ HERO ══ -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <h1 class="hero-name">Austin Larsen</h1>
        <p class="hero-title">Threat Intelligence</p>

        <p class="hero-bio">
          Leading rapid response and investigations into major global cyber events.
          Previously Mandiant incident response. Nation-state threats, zero-days, and data extortion campaigns.
        </p>
        <div class="hero-cta">
          <a href="/blog" class="btn btn-primary">Blog</a>
          <a href="#research" class="btn btn-ghost">Research</a>
        </div>
      </div>
      <div class="hero-terminal">
        <Terminal />
      </div>
    </div>
  </section>

  <!-- ══ RECENT BLOG ══ -->
  {recentBlog.length > 0 && (
    <section class="section" id="blog-preview">
      <div class="container">
        <p class="section-label">// latest</p>
        <h2 class="section-title">Recent Posts</h2>
        <div class="grid-2">
          {recentBlog.map((post) => (
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="card blog-card">
              <time class="blog-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
              <h3 class="blog-card-title">{post.data.title}</h3>
              {post.data.description && <p class="blog-card-desc">{post.data.description}</p>}
              {post.data.tags.length > 0 && (
                <div class="blog-tags">
                  {post.data.tags.map((tag) => <span class="badge">{tag}</span>)}
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══ RESEARCH ══ -->
  <section class="section" id="research">
    <div class="container">
      <p class="section-label">// publications</p>
      <h2 class="section-title">Research &amp; Publications</h2>
      <div class="research-list">
        {research.map((item) => (
          <a href={item.data.url} target="_blank" rel="noopener" class="card research-card">
            <div class="research-meta">
              <span class="badge">{item.data.publisher}</span>
              <time>{item.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</time>
            </div>
            <h3 class="research-title">{item.data.title}</h3>
            {item.data.tags.length > 0 && (
              <div class="research-tags">
                {item.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ TALKS ══ -->
  <section class="section" id="talks">
    <div class="container">
      <p class="section-label">// conferences</p>
      <h2 class="section-title">Talks &amp; Presentations</h2>
      <div class="grid-3 talks-grid">
        {talks.map((talk) => (
          <a href={talk.data.url} target="_blank" rel="noopener" class="card talk-card">
            {talk.data.image && (
              <div class="talk-img-wrap">
                <img src={talk.data.image} alt={talk.data.conference} loading="lazy" />
              </div>
            )}
            <div class="talk-info">
              <h3 class="talk-name">{talk.data.conference}</h3>
              <time class="talk-date">{talk.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</time>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ MEDIA ══ -->
  <section class="section" id="media">
    <div class="container">
      <p class="section-label">// press &amp; coverage</p>
      <h2 class="section-title">Media</h2>

      {featuredMedia.length > 0 && (
        <div class="media-carousel-wrap">
          <div class="media-carousel">
            {featuredMedia.map((item) => (
              <a href={item.data.url} target="_blank" rel="noopener" class="media-feature-card">
                {item.data.image && (
                  <div class="media-feature-img">
                    <img src={item.data.image} alt={item.data.title} loading="lazy" />
                    <div class="media-feature-overlay"></div>
                    {item.data.quote && (
                      <div class="media-feature-quote-overlay">
                        <p class="media-feature-quote">{item.data.quote}</p>
                      </div>
                    )}
                  </div>
                )}
                <div class="media-feature-info">
                  <div class="media-feature-meta">
                    <span class="media-feature-outlet">{item.data.outlet}</span>
                    <span class="badge">{item.data.type}</span>
                  </div>
                  <h3 class="media-feature-title">{item.data.title}</h3>
                  <time class="media-feature-date">{item.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</time>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {listMedia.length > 0 && (
        <ul class="media-list">
          {listMedia.map((item) => (
            <li class="media-list-item">
              <a href={item.data.url} target="_blank" rel="noopener" class:list={['media-list-link', { 'has-quote': !!item.data.quote }]}>
                <span class="media-list-outlet">{item.data.outlet}</span>
                <div class="media-list-center">
                  <span class="media-list-title">{item.data.title}</span>
                  {item.data.quote && (
                    <span class="media-list-quote">{item.data.quote}</span>
                  )}
                </div>
                <time class="media-list-date">{item.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</time>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

</Base>

<style>
  /* ── Hero ── */
  .hero {
    padding-top: calc(var(--nav-height) + 60px);
    padding-bottom: 60px;
    background: var(--bg-deep);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .hero-name {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 8px;
    background: linear-gradient(135deg, var(--text-primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-title {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 2px;
  }
  .hero-org {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 20px;
  }
  .hero-bio {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 28px;
  }
  .hero-cta {
    display: flex;
    gap: 12px;
  }
  .hero-terminal {
    display: flex;
    justify-content: flex-end;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 10px 24px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.2s;
  }
  .btn-primary {
    background: var(--accent);
    color: var(--bg-deep);
  }
  .btn-primary:hover {
    background: var(--accent-dim);
    color: var(--bg-deep);
    box-shadow: 0 0 24px var(--accent-glow);
  }
  .btn-ghost {
    border: 1px solid var(--border);
    color: var(--text-secondary);
  }
  .btn-ghost:hover {
    border-color: var(--text-muted);
    color: var(--text-primary);
  }

  /* ── Blog cards ── */
  .blog-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 8px;
  }
  .blog-card-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--text-primary);
  }
  .blog-card-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 12px;
  }
  .blog-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .blog-card {
    display: block;
    color: inherit;
  }
  .blog-card:hover { color: inherit; }

  /* ── Research ── */
  .research-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .research-card {
    display: block;
    color: inherit;
  }
  .research-card:hover { color: inherit; }
  .research-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  .research-meta time {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  .research-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
  }
  .research-tags {
    display: flex;
    gap: 8px;
    margin-top: 8px;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  /* ── Talks ── */
  .talk-card {
    display: block;
    color: inherit;
    padding: 0;
    overflow: hidden;
  }
  .talk-card:hover { color: inherit; }
  .talk-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--bg-surface);
  }
  .talk-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .talk-card:hover .talk-img-wrap img {
    transform: scale(1.05);
  }
  .talk-info {
    padding: 16px;
  }
  .talk-name {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .talk-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* ── Media featured carousel ── */
  .media-carousel-wrap {
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    margin-bottom: 32px;
  }
  .media-carousel-wrap::-webkit-scrollbar { display: none; }
  .media-carousel {
    display: grid;
    grid-template-columns: repeat(4, minmax(260px, 1fr));
    gap: 16px;
    padding-bottom: 4px;
  }
  .media-feature-card {
    display: flex;
    flex-direction: column;
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
    text-decoration: none;
    flex-shrink: 0;
  }
  .media-feature-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 20px var(--accent-glow);
    color: inherit;
  }
  .media-feature-img {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-deep);
  }
  .media-feature-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
    display: block;
  }
  .media-feature-card:hover .media-feature-img img {
    transform: scale(1.04);
  }
  .media-feature-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, color-mix(in srgb, var(--bg-deep) 60%, transparent) 0%, transparent 60%);
    transition: opacity 0.3s;
  }
  .media-feature-card:hover .media-feature-overlay {
    opacity: 0;
  }
  .media-feature-quote-overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--bg-deep) 88%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.25s, transform 0.25s;
  }
  .media-feature-card:hover .media-feature-quote-overlay {
    opacity: 1;
    transform: translateY(0);
  }
  .media-feature-quote {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.6;
    text-align: center;
    font-style: italic;
  }
  .media-feature-info {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  .media-feature-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .media-feature-outlet {
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .media-feature-title {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--text-primary);
  }
  .media-feature-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-top: auto;
    padding-top: 4px;
  }

  /* ── Media plain list ── */
  .media-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  .media-list-item + .media-list-item {
    border-top: 1px solid var(--border);
  }
  .media-list-link {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    align-items: start;
    gap: 16px;
    padding: 14px 20px;
    color: inherit;
    text-decoration: none;
    transition: background 0.15s;
    min-height: 52px;
  }
  .media-list-outlet,
  .media-list-date {
    padding-top: 2px; /* optical alignment with title baseline */
  }
  .media-list-link:hover {
    background: var(--bg-surface);
    color: inherit;
  }
  .media-list-outlet {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  /* Center column: title + expanding quote */
  .media-list-center {
    min-width: 0;
  }
  .media-list-title {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.4;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: opacity 0.2s ease, color 0.2s ease;
  }
  .media-list-quote {
    font-size: 0.82rem;
    color: var(--accent);
    line-height: 1.55;
    font-style: italic;
    display: block;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.25s ease, padding-top 0.25s ease;
    padding-top: 0;
  }
  .has-quote:hover .media-list-title {
    opacity: 0.35;
    white-space: normal;
  }
  .has-quote:hover .media-list-quote {
    max-height: 6rem;
    opacity: 1;
    padding-top: 5px;
  }
  .has-quote:hover .media-list-outlet {
    color: var(--text-primary);
  }
  .media-list-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-bio { margin: 0 auto 28px; }
    .hero-cta { justify-content: center; }
    .hero-terminal { justify-content: center; }
    .hero-name { font-size: 2.2rem; }
  }
  @media (max-width: 768px) {
    .talks-grid { grid-template-columns: repeat(2, 1fr); }
    .media-carousel { grid-template-columns: repeat(2, minmax(220px, 1fr)); }
    .media-list-link { grid-template-columns: 110px 1fr; }
    .media-list-date { display: none; }
  }
  @media (max-width: 480px) {
    .talks-grid { grid-template-columns: 1fr; }
    .media-carousel { grid-template-columns: repeat(2, minmax(200px, 1fr)); }
    .media-list-link { grid-template-columns: 90px 1fr; gap: 10px; padding: 12px 14px; }
  }
</style>
